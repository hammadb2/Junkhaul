# ============================================================
# Junk Haul Calgary — environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local
# ============================================================

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# STRIPE (use sk_test_ / pk_test_ for development)
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# QUO (SMS — https://www.quo.com/docs)
QUO_API_KEY=xxxxx
QUO_PHONE_NUMBER=+15873250751
QUO_PHONE_NUMBER_ID=PNxxxxx
QUO_USER_ID=USxxxxx

# VAPI (voice agents)
VAPI_API_KEY=xxxxx
VAPI_PHONE_NUMBER_ID=xxxxx
VAPI_BOOKING_AGENT_ID=xxxxx
VAPI_CS_AGENT_ID=xxxxx
# Shared secret used to authenticate inbound Vapi tool/webhook requests
VAPI_SERVER_SECRET=change_me

# GROQ (photo/description AI — https://console.groq.com)
GROQ_API_KEY=gsk_xxxxx

# OPERATORS
HAMMAD_PHONE=+15873250751
BROTHER_PHONE=+15873250751

# ADMIN
ADMIN_PASSWORD=your_secure_password

# SITE
NEXT_PUBLIC_SITE_URL=https://junkhaul.ca
NEXT_PUBLIC_GOOGLE_BUSINESS_REVIEW_LINK=https://junkhaul.ca

# MAPS — all free OpenStreetMap stack, no keys required
# Geocoding: Nominatim (https://nominatim.openstreetmap.org)
# Routing:   OSRM (https://router.project-osrm.org)
# Display:   Leaflet + OSM tiles (https://leafletjs.com)
NOMINATIM_URL=https://nominatim.openstreetmap.org
OSRM_URL=https://router.project-osrm.org
