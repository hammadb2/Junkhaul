/// Example secrets file. Copy to secrets.dart and fill in your tokens.
///
/// secrets.dart is gitignored — never commit real tokens.
class AppSecrets {
  AppSecrets._();

  static const String mapboxAccessToken = String.fromEnvironment(
    'MAPBOX_ACCESS_TOKEN',
    defaultValue: '', // Put your Mapbox token here, or pass via --dart-define
  );
}
