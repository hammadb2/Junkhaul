/// Example secrets file. Copy to secrets.dart and fill in your tokens.
///
/// secrets.dart is gitignored — never commit real tokens.
class AppSecrets {
  AppSecrets._();

  static const String mapboxAccessToken = String.fromEnvironment(
    'MAPBOX_ACCESS_TOKEN',
    defaultValue: '', // Put your Mapbox token here, or pass via --dart-define
  );

  /// Google Maps API key for the schedule map (google_maps_flutter).
  /// Use a restricted key (Android package name + SHA, iOS bundle ID).
  static const String googleMapsApiKey = String.fromEnvironment(
    'GOOGLE_MAPS_API_KEY',
    defaultValue: '',
  );

  /// Google Navigation API key for turn-by-turn navigation
  /// (google_navigation_flutter). Can be the same key as the maps key if
  /// the API restrictions allow both Maps SDK and Navigation SDK.
  static const String googleNavigationApiKey = String.fromEnvironment(
    'GOOGLE_NAVIGATION_API_KEY',
    defaultValue: '',
  );
}
