# Disposable/local Supabase integration-test environment only.
# Never point these values at production.

TEST_ENVIRONMENT=staging
TEST_PROJECT_REF=your-disposable-project-ref
APPROVED_TEST_PROJECT_REF=your-disposable-project-ref
ALLOW_TEST_DATABASE_RESET=true
ALLOW_REMOTE_TEST_DATABASE=true

TEST_SUPABASE_URL=https://your-disposable-project-ref.supabase.co
TEST_SUPABASE_SERVICE_ROLE_KEY=replace-with-disposable-service-role-key
TEST_SUPABASE_ANON_KEY=replace-with-disposable-anon-key
TEST_DATABASE_URL=postgresql://postgres:password@host:5432/postgres
TEST_STORAGE_BUCKET=donation-photos

# Route-level tests require the app to be running against the same disposable
# Supabase project, with QUO_TEST_MODE=true and matching webhook signing secret.
TEST_APP_BASE_URL=http://127.0.0.1:3000
TEST_QUO_WEBHOOK_SIGNING_SECRET=base64-encoded-test-signing-secret

INTEGRATION_APPLY_MIGRATIONS=true
